{
  "name": "@airwise/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --config ../../nodemon.json --watch src --watch ../../packages/config/dist --watch ../../packages/database/dist --watch ../../packages/domain/dist --watch ../../packages/rules/dist --exec \"node --import tsx src/main.ts\"",
    "dev:once": "node --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@airwise/config": "*",
    "@airwise/database": "*",
    "@airwise/domain": "*",
    "@airwise/rules": "*",
    "fastify": "^5.2.1",
    "zod": "^3.24.4"
  }
}
