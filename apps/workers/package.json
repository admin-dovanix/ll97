{
  "name": "@airwise/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --config ../../nodemon.json --watch src --watch ../../packages/config/dist --watch ../../packages/rules/dist --exec \"node --import tsx src/main.ts\"",
    "dev:once": "node --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@airwise/config": "*",
    "@airwise/rules": "*"
  }
}
